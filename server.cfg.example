# ═══════════════════════════════════════════════════════════════════
#  HD_FRAMEWORK SERVER — EXAMPLE server.cfg
#  Fill in the placeholders (license key, MySQL connection string)
#  before starting. Resource order below matters — don't reshuffle it.
# ═══════════════════════════════════════════════════════════════════

sv_hostname "HD Framework | United Kingdom Roleplay"
sv_maxclients 48
sv_licenseKey "changeme-get-one-at-keymaster.fivem.net"
sets sv_projectName "HD Framework"

set mysql_connection_string "mysql://user:password@localhost/hd_framework?charset=utf8mb4"

add_ace group.admin command allow
add_ace group.admin hd.admin allow
add_principal identifier.license:CHANGEME group.admin

ensure mapmanager
ensure baseevents
ensure chat
ensure spawnmanager
ensure sessionmanager
ensure basic-gamemode
ensure hardcap

# ── Database ─────────────────────────────────────────────────────
ensure oxmysql

# ── Voice (pma-voice — NOT included, download separately, see README)
# voice_enableRadios is required or hd_radio's channels carry no audio
# at all. voice_defaultRadio is pma-voice's own default anyway (LMENU)
# — set explicitly here so it's not a mystery to whoever reads this file.
setr voice_enableRadios 1
setr voice_defaultRadio "LMENU"
setr voice_enableRadioAnim 1
setr voice_disableVehicleRadioAnim 1
ensure pma-voice

# ── HD_Framework core + QBCore-ecosystem compatibility bridge ──────
ensure HD_Framework
ensure qb-core

# ── Staff admin panel (/admin) — gated on hd.admin, same ACE as above ─
ensure hd_admin

# ── Vehicle locking + shared keys (reads player_vehicles directly) ──
ensure HD_vehiclekeys

# ── Society/business funds (police/ambulance/cardealer wages) ───────
ensure hd_society

# ── Fines/invoices — the revenue mechanic feeding police/UHS funds ──
ensure hd_fines

# ── Emergency service jobs ──────────────────────────────────────────
ensure uk_policejob
ensure uk_uhsjob

# ── MDT (linked to police + UHS via config.lua Config.Departments) ──
ensure hazy_mdt

# ── Dispatch: 999 → police/UHS, breakdowns → any type='mechanic' job ─
ensure hd_dispatch

# ── Inventory: player grid, hotbar, stashes, glovebox/trunk, drops ──
ensure hd_inventory

# ── Mechanic shops: MOT/insurance, damage diagnostics, limp mode ───
# (repairkit_advanced hooks hd_inventory's onItemUsed extension point)
ensure hd_mechanic

# ── Radio: pma-voice channels gated on the 'radio' item + UK PTT tone
ensure hd_radio

# ── Phone: Contacts, Messages, Calls (now real audio via pma-voice),
#    Wire/Picta/Loopz, Garages ────────────────────────────────────────
ensure hd_phone

# ── Civilian jobs: shift/contract loops + vehicle dealership ────────
ensure hd_civjobs
ensure hd_cardealer
