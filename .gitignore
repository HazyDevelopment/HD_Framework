# Contains a real sv_licenseKey and live DB credentials — never commit this.
# Copy server.cfg.example to server.cfg and fill in your own values.
server.cfg

server-boot.log
server-boot-err.log

# FXServer runtime artifacts, created on first boot — not source.
cache/
.replxx_history

# External resources, deliberately not bundled — see README's Install
# section (oxmysql, pma-voice). Fetch your own copy from upstream.
resources/\[hd\]/oxmysql/
resources/\[voice\]/pma-voice/

# FXServer/txAdmin's own default base-resource pack (mapmanager,
# baseevents, chat, spawnmanager, sessionmanager, basic-gamemode,
# hardcap, plus a few unused example resources) — comes bundled with
# any FXServer/txAdmin setup, not something this project provides or
# owns. Kept locally so server.cfg's base `ensure` lines actually
# resolve, never committed.
resources/\[gamemodes\]/
resources/\[gameplay\]/
resources/\[local\]/
resources/\[managers\]/
resources/\[system\]/
resources/\[test\]/
